{
  "name": "md-editor-plus",
  "displayName": "MD Editor Plus",
  "description": "Notion-style block editor for Markdown. Edit .md files inline with rich blocks, drag-to-reorder, slash commands, callouts, and polished light/dark themes.",
  "version": "0.1.0",
  "publisher": "AviranRevach",
  "license": "MIT",
  "author": {
    "name": "Aviran Revach",
    "email": "aviran@atera.com"
  },
  "homepage": "https://github.com/aviranrevach/md-editor-plus#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/aviranrevach/md-editor-plus.git"
  },
  "bugs": {
    "url": "https://github.com/aviranrevach/md-editor-plus/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0F0F0F",
    "theme": "dark"
  },
  "categories": [
    "Notebooks",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "markdown",
    "md",
    "editor",
    "viewer",
    "wysiwyg",
    "block editor",
    "notion",
    "notion-style",
    "preview",
    "notes",
    "mdx"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "md-editor-plus.editor",
        "displayName": "MD Editor Plus",
        "selector": [
          { "filenamePattern": "*.md" },
          { "filenamePattern": "*.markdown" },
          { "filenamePattern": "*.mdown" },
          { "filenamePattern": "*.mkd" },
          { "filenamePattern": "*.mdx" }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "mdEditorPlus.openSourceView",
        "title": "MD Editor Plus: Open Source View"
      },
      {
        "command": "mdEditorPlus.openBlockView",
        "title": "MD Editor Plus: Open Block View"
      }
    ],
    "configuration": {
      "title": "MD Editor Plus",
      "properties": {
        "mdEditorPlus.theme": {
          "type": "string",
          "enum": ["auto", "light", "sepia", "claude", "dark"],
          "default": "light",
          "description": "Default color theme (saved via 'Save view as default')"
        },
        "mdEditorPlus.font": {
          "type": "string",
          "enum": ["sans", "serif", "mono"],
          "default": "sans",
          "description": "Default font family"
        },
        "mdEditorPlus.textSize": {
          "type": "string",
          "enum": ["s", "m", "l", "xl"],
          "default": "m",
          "description": "Default text size"
        },
        "mdEditorPlus.pageWidth": {
          "type": "number",
          "default": 800,
          "minimum": 400,
          "maximum": 2400,
          "description": "Default page width in pixels"
        },
        "mdEditorPlus.fullWidth": {
          "type": "boolean",
          "default": false,
          "description": "Default to full window width"
        },
        "mdEditorPlus.alwaysDarkCode": {
          "type": "boolean",
          "default": false,
          "description": "Render code blocks with a dark background regardless of page theme"
        },
        "mdEditorPlus.alwaysDarkSource": {
          "type": "boolean",
          "default": false,
          "description": "Render the raw source view with a dark background regardless of page theme"
        },
        "mdEditorPlus.sourceFullWidth": {
          "type": "boolean",
          "default": false,
          "description": "Always render the source (Code) view at full window width"
        },
        "mdEditorPlus.shortenCodeSnippets": {
          "type": "boolean",
          "default": false,
          "description": "Collapse long code snippets to a preview with a Show more button"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p tsconfig.json && node esbuild.config.js",
    "watch": "concurrently \"tsc -p tsconfig.json -w\" \"node esbuild.config.js --watch\"",
    "test": "jest",
    "package": "vsce package",
    "publish:vscode": "vsce publish",
    "publish:openvsx": "ovsx publish"
  },
  "devDependencies": {
    "@phosphor-icons/core": "^2.1.1",
    "@tiptap/core": "^2.7.0",
    "@tiptap/extension-bubble-menu": "^2.27.2",
    "@tiptap/extension-code-block-lowlight": "^2.7.0",
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.7.0",
    "@tiptap/extension-link": "^2.7.0",
    "@tiptap/extension-table": "^2.7.0",
    "@tiptap/extension-table-cell": "^2.7.0",
    "@tiptap/extension-table-header": "^2.7.0",
    "@tiptap/extension-table-row": "^2.7.0",
    "@tiptap/extension-task-item": "^2.7.0",
    "@tiptap/extension-task-list": "^2.7.0",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/starter-kit": "^2.7.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.0.0",
    "ovsx": "^0.9.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.21.0",
    "jest": "^29.0.0",
    "lowlight": "^3.1.0",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "tiptap-markdown": "^0.8.10",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "\\.css$": "<rootDir>/tests/__mocks__/fileMock.js"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.webview.json"
        }
      ]
    }
  }
}
